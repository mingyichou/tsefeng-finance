# 範例 secrets 檔案
# 本機開發：複製為 secrets.toml 並填入真實值
# Streamlit Cloud 部署：把此內容貼到 App Settings → Secrets 介面

[supabase]
url = "https://YOUR_PROJECT_REF.supabase.co"
publishable_key = "sb_publishable_XXXXXXXXXXXXXXXXXXXXXX"
# secret_key 暫時不需要（前端用 publishable + RLS 即可）
# 之後若有後端匯入腳本才加：
# secret_key = "sb_secret_XXXXXXXXXXXXXXXXXXXXXX"

[cookies]
# 加密 cookie 用的 password（任意 32+ 字元隨機字串）
# 產生方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
password = "請填入 32 字元以上的隨機字串"
